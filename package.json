{
  "name": "kidsafe-hermes-runtime",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace apps/web run dev",
    "build": "npm --workspace apps/web run build",
    "start": "npm --workspace apps/web run start",
    "lint": "npm --workspace apps/web run lint",
    "typecheck": "npm --workspace apps/web run typecheck",
    "test:runtime": "node scripts/hermes/runtime-contract-smoke.mjs",
    "verify": "npm run typecheck && npm run build",
    "hermes:provision-child": "node scripts/hermes/provision-child-profile.mjs",
    "hermes:runtime": "node scripts/hermes/runtime-manager.mjs",
    "hermes:runtime-server": "node scripts/hermes/runtime-manager-server.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
